{
  "name": "@iina-watch-party/plugin",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "bun run build:main && bun run build:overlay && bun run build:sidebar",
    "build:main": "bun build src/main.ts --outdir build/src --format esm",
    "build:overlay": "cp ui/overlay/* build/ui/overlay/",
    "build:sidebar": "cp ui/sidebar/* build/ui/sidebar/",
    "prebuild": "bun run scripts/prepare-build.ts",
    "link": "iina-plugin link build",
    "pack": "iina-plugin pack build"
  },
  "dependencies": {
    "@iina-watch-party/shared": "workspace:*"
  }
}
