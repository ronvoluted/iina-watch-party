{
  "name": "Watch Party",
  "identifier": "com.ronvoluted.iina-watch-party",
  "version": "0.3.0",
  "description": "Sync playback between devices over a real-time channel",
  "author": {
    "name": "ronvoluted"
  },
  "entry": "src/main.js",
  "permissions": [
    "show-osd",
    "network-request",
    "video-overlay"
  ],
  "sidebarTab": {
    "name": "Watch Party"
  },
  "preferencesPage": "prefs/index.html",
  "preferenceDefaults": {
    "backendUrl": "",
    "displayName": "",
    "driftThresholdMs": 2000
  },
  "allowedDomains": [
    "localhost:*",
    "127.0.0.1:*",
    "*.workers.dev:*"
  ]
}
